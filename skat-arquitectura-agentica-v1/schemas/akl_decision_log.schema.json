{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "arketlabs/contracts/akl_decision_log",
  "title": "AKL Decision Log",
  "description": "Audit-trail append-only de decisiones de agente. Clave estable (category, subject): un cambio de decision se apila como nueva entrada reusando category+subject, moviendo la opcion superada a options_considered con rejected_because. Nunca se edita una entrada previa. Clean-room ArketLabs.",
  "type": "object",
  "required": ["version", "folio", "decisions"],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "folio": { "type": "string", "pattern": "^AKL-[0-9]{4}-[A-Z0-9]+-.+$" },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["decision_id", "instancia", "category", "subject", "options_considered", "selected", "reason"],
        "properties": {
          "decision_id": { "type": "string", "pattern": "^d-[0-9]{3,}$", "description": "ID estable, ej. d-001" },
          "instancia": { "type": "string", "enum": ["web", "code", "cowork"] },
          "category": {
            "type": "string",
            "enum": [
              "seleccion_pipeline",
              "seleccion_proveedor_llm",
              "seleccion_proveedor_media",
              "credencial",
              "esquema_supabase",
              "esquema_airtable",
              "nodo_legacy",
              "runtime_render",
              "fallback",
              "downgrade_approval",
              "budget_tradeoff",
              "approval_policy",
              "capability_extension",
              "deploy_cliente",
              "otro"
            ]
          },
          "subject": { "type": "string", "description": "Que se decide. Junto con category forma la clave estable." },
          "options_considered": {
            "type": "array",
            "minItems": 2,
            "description": "TODAS las opciones evaluadas, incluidas las rechazadas. Minimo 2 (si de verdad solo habia una, incluye la no-disponible con rejected_because).",
            "items": {
              "type": "object",
              "required": ["option_id", "descripcion"],
              "properties": {
                "option_id": { "type": "string" },
                "descripcion": { "type": "string" },
                "score": { "type": "number", "minimum": 0, "maximum": 1 },
                "rejected_because": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "selected": { "type": "string", "description": "option_id ganador" },
          "reason": {
            "type": "string",
            "minLength": 12,
            "description": "Razon concreta, NO boilerplate. 'best option' / 'mejor opcion' no es una razon valida."
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Confianza realista. Todo a 1.0 en todas las decisiones = sospechoso, se marca."
          },
          "user_visible": { "type": "boolean" },
          "user_approved": { "type": "boolean" },
          "supersedes": { "type": "string", "description": "decision_id de la entrada previa que esta revision reemplaza (misma category+subject)" },
          "timestamp": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    },
    "metadata": { "type": "object" }
  },
  "additionalProperties": false
}
